@model IEnumerable<UniversityTimetable.Domain.Entities.Lecturer>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Faculty & Lecturers";
    var departments = ViewBag.Departments as List<UniversityTimetable.Domain.Entities.Department> ?? new List<UniversityTimetable.Domain.Entities.Department>();
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h3 class="fw-bold mb-1"><i class="fa-solid fa-user-tie text-secondary me-2"></i>Lecturer Directory & Workload</h3>
        <p class="text-muted mb-0">Manage faculty members, max weekly workloads, availability, and course allocations.</p>
    </div>
    <button class="btn btn-primary fw-semibold" data-bs-toggle="modal" data-bs-target="#createModal">
        <i class="fa-solid fa-plus me-2"></i>Register New Lecturer
    </button>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card-custom">
    <div class="card-body">
        <table class="table table-hover datatable">
            <thead class="table-light">
                <tr>
                    <th>Emp ID</th>
                    <th>Full Name & Email</th>
                    <th>Department</th>
                    <th>Max Workload</th>
                    <th>Assigned Courses</th>
                    <th>Available Days</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var l in Model)
                {
                    <tr>
                        <td><span class="badge bg-secondary-subtle text-secondary fw-bold fs-6">@l.EmployeeId</span></td>
                        <td>
                            <div class="fw-bold">@l.FullName</div>
                            <small class="text-muted"><i class="fa-regular fa-envelope me-1"></i>@l.Email</small>
                        </td>
                        <td>@l.Department?.Name</td>
                        <td><span class="badge bg-dark">@l.MaxWeeklyWorkloadHours Hrs / Wk</span></td>
                        <td><span class="badge bg-primary">@l.AssignedCourses.Count Courses</span></td>
                        <td><small class="text-muted">@l.AvailableDays</small></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-1" onclick="editLecturer(@l.Id, '@l.EmployeeId', '@l.FullName', '@l.Email', '@l.Phone', @l.DepartmentId, @l.MaxWeeklyWorkloadHours, '@l.AvailableDays')">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </button>
                            <form action="/Admin/Lecturer/Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this lecturer?');">
                                <input type="hidden" name="id" value="@l.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <form action="/Admin/Lecturer/Create" method="post">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold"><i class="fa-solid fa-plus me-2"></i>Register Lecturer</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Employee ID</label>
                            <input type="text" name="EmployeeId" class="form-control" placeholder="e.g. LEC-005" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Full Name</label>
                            <input type="text" name="FullName" class="form-control" placeholder="e.g. Dr. John von Neumann" required />
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Email Address</label>
                            <input type="email" name="Email" class="form-control" placeholder="e.g. j.neumann@university.edu" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Phone Number</label>
                            <input type="text" name="Phone" class="form-control" placeholder="+123 456 7890" />
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Department</label>
                            <select name="DepartmentId" class="form-select" required>
                                @foreach (var d in departments) { <option value="@d.Id">@d.Name</option> }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Max Weekly Workload (Hours)</label>
                            <input type="number" name="MaxWeeklyWorkloadHours" class="form-control" value="18" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Available Days (CSV)</label>
                        <input type="text" name="AvailableDays" class="form-control" value="Monday,Tuesday,Wednesday,Thursday,Friday" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary fw-semibold">Save Lecturer</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <form action="/Admin/Lecturer/Edit" method="post">
            <input type="hidden" name="Id" id="editId" />
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold"><i class="fa-solid fa-pen-to-square me-2"></i>Edit Lecturer</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Employee ID</label>
                            <input type="text" name="EmployeeId" id="editEmpId" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Full Name</label>
                            <input type="text" name="FullName" id="editName" class="form-control" required />
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Email Address</label>
                            <input type="email" name="Email" id="editEmail" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Phone Number</label>
                            <input type="text" name="Phone" id="editPhone" class="form-control" />
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Department</label>
                            <select name="DepartmentId" id="editDeptId" class="form-select" required>
                                @foreach (var d in departments) { <option value="@d.Id">@d.Name</option> }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Max Weekly Workload (Hours)</label>
                            <input type="number" name="MaxWeeklyWorkloadHours" id="editWorkload" class="form-control" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Available Days (CSV)</label>
                        <input type="text" name="AvailableDays" id="editAvailableDays" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary fw-semibold">Save Changes</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function editLecturer(id, empId, name, email, phone, deptId, workload, availableDays) {
            $('#editId').val(id);
            $('#editEmpId').val(empId);
            $('#editName').val(name);
            $('#editEmail').val(email);
            $('#editPhone').val(phone || '');
            $('#editDeptId').val(deptId);
            $('#editWorkload').val(workload);
            $('#editAvailableDays').val(availableDays);
            new bootstrap.Modal(document.getElementById('editModal')).show();
        }
    </script>
}
