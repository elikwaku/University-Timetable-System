@model IEnumerable<UniversityTimetable.Domain.Entities.Programme>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Programme Management";
    var departments = ViewBag.Departments as List<UniversityTimetable.Domain.Entities.Department> ?? new List<UniversityTimetable.Domain.Entities.Department>();
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h3 class="fw-bold mb-1"><i class="fa-solid fa-book-bookmark text-info me-2"></i>Programme Management</h3>
        <p class="text-muted mb-0">Configure degree programmes, levels, and department assignments.</p>
    </div>
    <button class="btn btn-primary fw-semibold" data-bs-toggle="modal" data-bs-target="#createModal">
        <i class="fa-solid fa-plus me-2"></i>Add New Programme
    </button>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card-custom">
    <div class="card-body">
        <table class="table table-hover datatable">
            <thead class="table-light">
                <tr>
                    <th>Programme Code</th>
                    <th>Degree Name</th>
                    <th>Department</th>
                    <th>Courses</th>
                    <th>Student Groups</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var prog in Model)
                {
                    <tr>
                        <td><span class="badge bg-info-subtle text-info fw-bold fs-6">@prog.Code</span></td>
                        <td class="fw-bold">@prog.Name</td>
                        <td>@prog.Department?.Name</td>
                        <td><span class="badge bg-secondary">@prog.Courses.Count Courses</span></td>
                        <td><span class="badge bg-success">@prog.StudentGroups.Count Groups</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-1" onclick="editProg(@prog.Id, '@prog.Code', '@prog.Name', @prog.DepartmentId)">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </button>
                            <form action="/Admin/Programme/Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this programme?');">
                                <input type="hidden" name="id" value="@prog.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <form action="/Admin/Programme/Create" method="post">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold"><i class="fa-solid fa-plus me-2"></i>Add Programme</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Programme Code</label>
                        <input type="text" name="Code" class="form-control" placeholder="e.g. BSC-CS" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Degree Title</label>
                        <input type="text" name="Name" class="form-control" placeholder="e.g. BSc Computer Science" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Assigning Department</label>
                        <select name="DepartmentId" class="form-select" required>
                            @foreach (var d in departments)
                            {
                                <option value="@d.Id">@d.Name (@d.Code)</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary fw-semibold">Save Programme</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <form action="/Admin/Programme/Edit" method="post">
            <input type="hidden" name="Id" id="editId" />
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold"><i class="fa-solid fa-pen-to-square me-2"></i>Edit Programme</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Programme Code</label>
                        <input type="text" name="Code" id="editCode" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Degree Title</label>
                        <input type="text" name="Name" id="editName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Assigning Department</label>
                        <select name="DepartmentId" id="editDeptId" class="form-select" required>
                            @foreach (var d in departments)
                            {
                                <option value="@d.Id">@d.Name (@d.Code)</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary fw-semibold">Save Changes</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function editProg(id, code, name, deptId) {
            $('#editId').val(id);
            $('#editCode').val(code);
            $('#editName').val(name);
            $('#editDeptId').val(deptId);
            new bootstrap.Modal(document.getElementById('editModal')).show();
        }
    </script>
}
