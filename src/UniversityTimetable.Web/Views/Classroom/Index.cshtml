@model IEnumerable<UniversityTimetable.Domain.Entities.Classroom>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Classrooms & Laboratories";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h3 class="fw-bold mb-1"><i class="fa-solid fa-door-open text-warning me-2"></i>Classroom & Lab Inventory</h3>
        <p class="text-muted mb-0">Manage lecture halls, computer laboratories, and room capacities.</p>
    </div>
    <button class="btn btn-primary fw-semibold" data-bs-toggle="modal" data-bs-target="#createModal">
        <i class="fa-solid fa-plus me-2"></i>Add Classroom / Lab
    </button>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4">
        <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card-custom">
    <div class="card-body">
        <table class="table table-hover datatable">
            <thead class="table-light">
                <tr>
                    <th>Room Number / Name</th>
                    <th>Capacity</th>
                    <th>Room Type</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td><span class="badge bg-warning-subtle text-warning fw-bold fs-6">@r.RoomNumber</span></td>
                        <td><span class="badge bg-dark">@r.Capacity Seats</span></td>
                        <td>
                            @switch (r.RoomType)
                            {
                                case UniversityTimetable.Domain.Enums.RoomType.ComputerLab:
                                    <span class="badge bg-info text-white"><i class="fa-solid fa-desktop me-1"></i>Computer Lab</span>
                                    break;
                                case UniversityTimetable.Domain.Enums.RoomType.Lab:
                                    <span class="badge bg-success text-white"><i class="fa-solid fa-flask me-1"></i>Science Lab</span>
                                    break;
                                case UniversityTimetable.Domain.Enums.RoomType.SeminarRoom:
                                    <span class="badge bg-purple text-white" style="background:#9333ea;"><i class="fa-solid fa-users-viewfinder me-1"></i>Seminar Room</span>
                                    break;
                                default:
                                    <span class="badge bg-primary"><i class="fa-solid fa-graduation-cap me-1"></i>Lecture Hall</span>
                                    break;
                            }
                        </td>
                        <td>
                            @if (r.IsActive) { <span class="badge bg-success">Active</span> }
                            else { <span class="badge bg-danger">Maintenance</span> }
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-1" onclick="editRoom(@r.Id, '@r.RoomNumber', @r.Capacity, @((int)r.RoomType), @r.IsActive.ToString().ToLower())">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </button>
                            <form action="/Admin/Classroom/Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this classroom?');">
                                <input type="hidden" name="id" value="@r.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <form action="/Admin/Classroom/Create" method="post">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold"><i class="fa-solid fa-plus me-2"></i>Add Classroom / Lab</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Room Number / Name</label>
                        <input type="text" name="RoomNumber" class="form-control" placeholder="e.g. ENG-101 or COMP-LAB-2" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Seating Capacity</label>
                        <input type="number" name="Capacity" class="form-control" value="60" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Room Type</label>
                        <select name="RoomType" class="form-select" required>
                            <option value="1">Lecture Hall</option>
                            <option value="2">Science Laboratory</option>
                            <option value="3">Computer Laboratory</option>
                            <option value="4">Seminar Room</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary fw-semibold">Save Classroom</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <form action="/Admin/Classroom/Edit" method="post">
            <input type="hidden" name="Id" id="editId" />
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold"><i class="fa-solid fa-pen-to-square me-2"></i>Edit Classroom</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Room Number / Name</label>
                        <input type="text" name="RoomNumber" id="editNumber" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Seating Capacity</label>
                        <input type="number" name="Capacity" id="editCapacity" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Room Type</label>
                        <select name="RoomType" id="editType" class="form-select" required>
                            <option value="1">Lecture Hall</option>
                            <option value="2">Science Laboratory</option>
                            <option value="3">Computer Laboratory</option>
                            <option value="4">Seminar Room</option>
                        </select>
                    </div>
                    <div class="form-check">
                        <input type="checkbox" name="IsActive" value="true" class="form-check-input" id="editActive">
                        <label class="form-check-label fw-semibold" for="editActive">Room Active & Available</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary fw-semibold">Save Changes</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function editRoom(id, number, capacity, type, active) {
            $('#editId').val(id);
            $('#editNumber').val(number);
            $('#editCapacity').val(capacity);
            $('#editType').val(type);
            $('#editActive').prop('checked', active);
            new bootstrap.Modal(document.getElementById('editModal')).show();
        }
    </script>
}
