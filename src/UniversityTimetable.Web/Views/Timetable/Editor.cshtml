@model UniversityTimetable.Domain.Entities.Timetable
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Interactive Timetable Editor";

    var days = new[] { DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday, DayOfWeek.Thursday, DayOfWeek.Friday };
    
    var timeWindowsList = new List<TimeSpan>();
    TimeSpan gridMin = (Model.Entries != null && Model.Entries.Any()) ? Model.Entries.Min(e => e.StartTime) : new TimeSpan(6, 30, 0);
    if (gridMin > new TimeSpan(6, 30, 0)) gridMin = new TimeSpan(6, 30, 0);
    TimeSpan gridMax = (Model.Entries != null && Model.Entries.Any()) ? Model.Entries.Max(e => e.EndTime) : new TimeSpan(19, 0, 0);
    if (gridMax < new TimeSpan(19, 0, 0)) gridMax = new TimeSpan(19, 0, 0);

    for (TimeSpan t = gridMin; t < gridMax; t = t.Add(TimeSpan.FromHours(1)))
    {
        timeWindowsList.Add(t);
    }
    var timeWindows = timeWindowsList.ToArray();

    var classrooms = ViewBag.Classrooms as List<UniversityTimetable.Domain.Entities.Classroom> ?? new List<UniversityTimetable.Domain.Entities.Classroom>();
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <div class="d-flex align-items-center gap-2">
            <h3 class="fw-bold mb-1"><i class="fa-solid fa-calendar-days text-primary me-2"></i>@Model.Title</h3>
            <span class="badge @(Model.Status == UniversityTimetable.Domain.Enums.TimetableStatus.Published ? "bg-success" : "bg-warning text-dark")">
                @Model.Status
            </span>
        </div>
        <p class="text-muted mb-0">Interactive Master Schedule | Drag, shift, lock entries, and inspect AI reasoning.</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/Admin/Timetable/ExportExcel/@Model.Id" class="btn btn-success fw-semibold">
            <i class="fa-solid fa-file-excel me-1"></i> Export Excel Template
        </a>
        <a href="/Admin/Timetable/ExportPrintHtml/@Model.Id" target="_blank" class="btn btn-outline-secondary">
            <i class="fa-solid fa-print me-1"></i> Print / PDF View
        </a>
        <a href="/Admin/Timetable/ExportCsv/@Model.Id" class="btn btn-outline-success">
            <i class="fa-solid fa-file-csv me-1"></i> Export CSV
        </a>
        @if (Model.Status != UniversityTimetable.Domain.Enums.TimetableStatus.Published)
        {
            <form action="/Admin/Timetable/Publish" method="post" class="d-inline">
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-success fw-semibold"><i class="fa-solid fa-globe me-2"></i>Publish Schedule to Student Portal</button>
            </form>
        }
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Clash Warning Banner -->
@if (Model.ClashReports != null && Model.ClashReports.Any(c => !c.IsResolved))
{
    var activeClashCount = Model.ClashReports.Count(c => !c.IsResolved);
    <div class="alert alert-danger shadow-sm mb-4">
        <div class="d-flex align-items-center justify-content-between mb-2">
            <div class="fw-bold fs-6">
                <i class="fa-solid fa-triangle-exclamation me-2"></i>Conflict Warning (@activeClashCount Active @(activeClashCount == 1 ? "Clash" : "Clashes") Detected)
            </div>
            <form action="/Admin/Timetable/ResolveClashes" method="post" class="d-inline">
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-sm btn-light fw-bold text-danger border shadow-sm">
                    <i class="fa-solid fa-wand-magic-sparkles me-1 text-primary"></i>Auto-Resolve Clashes with AI
                </button>
            </form>
        </div>
        <ul class="mb-0 small">
            @foreach (var clash in Model.ClashReports.Where(c => !c.IsResolved).Take(5))
            {
                <li class="mb-1">
                    <strong>[@clash.ConflictType]</strong> @clash.Description — <em>Recommendation: @clash.Recommendation</em>
                </li>
            }
        </ul>
    </div>
}

@{
    var periodSlots = new[] {
        new { Start = new TimeSpan(6, 30, 0), End = new TimeSpan(7, 30, 0), Label = "06:30 - 07:30", IsBreak = false },
        new { Start = new TimeSpan(7, 30, 0), End = new TimeSpan(8, 30, 0), Label = "07:30 - 08:30", IsBreak = false },
        new { Start = new TimeSpan(8, 30, 0), End = new TimeSpan(9, 30, 0), Label = "08:30 - 09:30", IsBreak = false },
        new { Start = new TimeSpan(9, 30, 0), End = new TimeSpan(10, 30, 0), Label = "09:30 - 10:30", IsBreak = false },
        new { Start = new TimeSpan(10, 30, 0), End = new TimeSpan(11, 30, 0), Label = "10:30 - 11:30", IsBreak = false },
        new { Start = new TimeSpan(11, 30, 0), End = new TimeSpan(12, 30, 0), Label = "11:30 - 12:30", IsBreak = false },
        new { Start = new TimeSpan(12, 30, 0), End = new TimeSpan(13, 0, 0), Label = "BREAK (12:30-13:00)", IsBreak = true },
        new { Start = new TimeSpan(13, 0, 0), End = new TimeSpan(14, 0, 0), Label = "13:00 - 14:00", IsBreak = false },
        new { Start = new TimeSpan(14, 0, 0), End = new TimeSpan(15, 0, 0), Label = "14:00 - 15:00", IsBreak = false },
        new { Start = new TimeSpan(15, 0, 0), End = new TimeSpan(16, 0, 0), Label = "15:00 - 16:00", IsBreak = false },
        new { Start = new TimeSpan(16, 0, 0), End = new TimeSpan(17, 0, 0), Label = "16:00 - 17:00", IsBreak = false },
        new { Start = new TimeSpan(17, 0, 0), End = new TimeSpan(18, 0, 0), Label = "17:00 - 18:00", IsBreak = false },
        new { Start = new TimeSpan(18, 0, 0), End = new TimeSpan(19, 0, 0), Label = "18:00 - 19:00", IsBreak = false }
    };
}

<!-- Weekly Master Grid -->
<div class="card-custom">
    <div class="card-header-custom d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <h6 class="fw-bold mb-0"><i class="fa-solid fa-table-cells me-2"></i>Weekly Schedule Workspace Grid</h6>
            <small class="text-muted" id="timeRangeSummary"><i class="fa-solid fa-clock me-1 text-primary"></i>Showing Full Day (06:30 - 19:00)</small>
        </div>

        <!-- Time Range Filter Bar -->
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <span class="badge bg-light text-dark fw-semibold border"><i class="fa-solid fa-filter me-1 text-primary"></i>Time Range:</span>
            <div class="btn-group btn-group-sm" role="group">
                <button type="button" class="btn btn-outline-primary active" onclick="applyQuickTimeFilter('06:30', '19:00', this)">Full Day</button>
                <button type="button" class="btn btn-outline-primary" onclick="applyQuickTimeFilter('06:30', '12:30', this)">Morning (06:30-12:30)</button>
                <button type="button" class="btn btn-outline-primary" onclick="applyQuickTimeFilter('13:00', '19:00', this)">Afternoon (13:00-19:00)</button>
            </div>

            <div class="d-flex align-items-center gap-1">
                <select id="gridTimeFrom" class="form-select form-select-sm" style="width: 105px;" onchange="customTimeFilterChanged()">
                    <option value="06:30">06:30 AM</option>
                    <option value="07:30">07:30 AM</option>
                    <option value="08:30">08:30 AM</option>
                    <option value="09:30">09:30 AM</option>
                    <option value="10:30">10:30 AM</option>
                    <option value="11:30">11:30 AM</option>
                    <option value="12:30">12:30 PM</option>
                    <option value="13:00">01:00 PM</option>
                    <option value="14:00">02:00 PM</option>
                    <option value="15:00">03:00 PM</option>
                    <option value="16:00">04:00 PM</option>
                    <option value="17:00">05:00 PM</option>
                    <option value="18:00">06:00 PM</option>
                </select>
                <span class="text-muted small">to</span>
                <select id="gridTimeTo" class="form-select form-select-sm" style="width: 105px;" onchange="customTimeFilterChanged()">
                    <option value="07:30">07:30 AM</option>
                    <option value="08:30">08:30 AM</option>
                    <option value="09:30">09:30 AM</option>
                    <option value="10:30">10:30 AM</option>
                    <option value="11:30">11:30 AM</option>
                    <option value="12:30">12:30 PM</option>
                    <option value="13:00">01:00 PM</option>
                    <option value="14:00">02:00 PM</option>
                    <option value="15:00">03:00 PM</option>
                    <option value="16:00">04:00 PM</option>
                    <option value="17:00">05:00 PM</option>
                    <option value="18:00">06:00 PM</option>
                    <option value="19:00" selected>07:00 PM</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Day-of-the-Week Navigation Tabs -->
    <div class="px-3 pt-3 bg-light border-bottom">
        <ul class="nav nav-tabs border-bottom-0" id="dayTabNav">
            <li class="nav-item">
                <button class="nav-link active fw-bold text-primary me-1" onclick="filterGridByDay('ALL', this)" style="border-radius: 8px 8px 0 0;">
                    <i class="fa-solid fa-calendar-days me-1"></i>All Days
                </button>
            </li>
            @foreach (var day in days)
            {
                <li class="nav-item">
                    <button class="nav-link fw-bold text-dark me-1" onclick="filterGridByDay('@day.ToString()', this)" style="border-radius: 8px 8px 0 0;">
                        <i class="fa-solid fa-calendar-day me-1 text-secondary"></i>@day.ToString()
                    </button>
                </li>
            }
        </ul>
    </div>

    <div class="card-body p-0 overflow-auto">
        <table class="table table-bordered mb-0 align-middle text-center" style="min-width: 1400px; border: 2px solid #0f172a;">
            <thead class="table-dark">
                <tr>
                    <th style="width: 130px; background-color: #0f172a;" class="text-center align-middle">DAY / TIME</th>
                    @foreach (var slot in periodSlots)
                    {
                        string startStr = slot.Start.ToString(@"hh\:mm");
                        string endStr = slot.End.ToString(@"hh\:mm");

                        if (slot.IsBreak)
                        {
                            <th class="slot-header text-center align-middle text-warning" data-start="@startStr" data-end="@endStr" style="width: 130px; background-color: #92400e;">
                                <i class="fa-solid fa-utensils d-block mb-1"></i>@slot.Label
                            </th>
                        }
                        else
                        {
                            <th class="slot-header text-center align-middle" data-start="@startStr" data-end="@endStr" style="min-width: 140px; background-color: #0f172a;">@slot.Label</th>
                        }
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var day in days)
                {
                    <tr data-day="@day.ToString()" class="day-grid-row">
                        <td class="fw-bold text-white text-center align-middle" style="width: 130px; font-size: 13px; background-color: #1e293b !important;">
                            @day.ToString().ToUpper()
                        </td>

                        @for (int i = 0; i < periodSlots.Length; i++)
                        {
                            var slot = periodSlots[i];
                            string startStr = slot.Start.ToString(@"hh\:mm");
                            string endStr = slot.End.ToString(@"hh\:mm");

                            if (slot.IsBreak)
                            {
                                <td class="slot-cell align-middle text-center p-2 small fw-bold border" data-start="@startStr" data-end="@endStr" style="background-color: #fef3c7 !important; color: #92400e;">
                                    <i class="fa-solid fa-utensils d-block mb-1"></i> BREAK
                                </td>
                                continue;
                            }

                            var entriesStartingHere = Model.Entries?
                                .Where(e => e.DayOfWeek == day && e.StartTime == slot.Start)
                                .ToList() ?? new List<UniversityTimetable.Domain.Entities.TimetableEntry>();

                            if (entriesStartingHere.Any())
                            {
                                int maxDuration = entriesStartingHere.Max(e => e.DurationHours);
                                int colSpan = maxDuration > 1 ? maxDuration : 1;
                                if (slot.Start < new TimeSpan(12, 30, 0) && slot.Start.Add(TimeSpan.FromHours(colSpan)) > new TimeSpan(12, 30, 0))
                                {
                                    colSpan = 1;
                                }

                                TimeSpan endTimeActual = slot.Start.Add(TimeSpan.FromHours(colSpan));
                                string entryEndStr = endTimeActual.ToString(@"hh\:mm");

                                <td colspan="@colSpan" class="slot-cell align-middle p-2" data-start="@startStr" data-end="@entryEndStr" style="vertical-align: top !important; min-width: 220px;">
                                    @if (entriesStartingHere.Count > 1)
                                    {
                                        <div class="badge bg-dark text-warning w-100 mb-2 py-1 shadow-sm border border-warning" style="font-size: 11px;">
                                            <i class="fa-solid fa-layer-group me-1"></i>@entriesStartingHere.Count Classes Parallel
                                        </div>
                                    }

                                    @foreach (var entryItem in entriesStartingHere)
                                    {
                                        string bgClass = entryItem.SessionType == UniversityTimetable.Domain.Enums.SessionType.CombinedClass ? "bg-purple-subtle border-purple text-purple"
                                            : entryItem.SessionType == UniversityTimetable.Domain.Enums.SessionType.ComputerLab || entryItem.SessionType == UniversityTimetable.Domain.Enums.SessionType.Lab ? "bg-success-subtle border-success text-success"
                                            : "bg-primary-subtle border-primary text-primary";

                                        <div class="card p-2 text-start shadow-sm mb-2 border @bgClass" style="border-left: 4px solid !important;">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <strong class="fs-6 text-dark">@entryItem.Course?.Code</strong>
                                                <button class="btn btn-sm p-0 text-secondary" onclick="toggleLock(@entryItem.Id, this)">
                                                    <i class="fa-solid @(entryItem.IsLocked ? "fa-lock text-danger" : "fa-lock-open")"></i>
                                                </button>
                                            </div>
                                            <div class="small fw-bold text-dark mb-1">@(entryItem.Course?.ShortForm ?? entryItem.Course?.Title)</div>
                                            <div class="small text-muted"><i class="fa-solid fa-door-open me-1 text-primary"></i><strong>Rm:</strong> @entryItem.Classroom?.RoomNumber (Cap @entryItem.Classroom?.Capacity)</div>
                                            <div class="small text-muted"><i class="fa-solid fa-user me-1 text-secondary"></i>@entryItem.Lecturer?.FullName</div>
                                            @if (entryItem.StudentGroup != null)
                                            {
                                                <div class="small text-dark fw-semibold"><i class="fa-solid fa-users me-1 text-info"></i>Grp: @entryItem.StudentGroup.Name (@entryItem.StudentGroup.StudentCount stds)</div>
                                            }
                                            @if (!string.IsNullOrEmpty(entryItem.Remarks))
                                            {
                                                <div class="small fw-bold text-purple"><i class="fa-solid fa-star me-1"></i>@entryItem.Remarks</div>
                                            }
                                            <div class="mt-2 d-flex justify-content-between align-items-center border-top pt-1">
                                                <span class="badge bg-dark" style="font-size:10px;">@entryItem.SessionType (@entryItem.DurationHours hrs)</span>
                                                <button class="btn btn-link btn-sm p-0 text-decoration-none" onclick="openMoveModal(@entryItem.Id, '@entryItem.DayOfWeek', '@entryItem.StartTime.ToString(@"hh\:mm")', @entryItem.ClassroomId)">
                                                    Move <i class="fa-solid fa-arrows-up-down-left-right"></i>
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </td>

                                i += (colSpan - 1);
                            }
                            else
                            {
                                bool coveredByPrevious = Model.Entries?
                                    .Any(e => e.DayOfWeek == day && e.StartTime < slot.Start && e.EndTime > slot.Start) ?? false;

                                if (!coveredByPrevious)
                                {
                                    <td class="slot-cell align-middle text-muted small border p-2 text-center" data-start="@startStr" data-end="@endStr" style="background-color: #fafafa; min-width: 110px;">
                                        <span class="text-black-50">-</span>
                                    </td>
                                }
                            }
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Move Session Modal -->
<div class="modal fade" id="moveModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-arrows-up-down-left-right me-2"></i>Move Session Slot</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="moveEntryId" />
                <div class="mb-3">
                    <label class="form-label fw-semibold">Target Day of Week</label>
                    <select id="moveDay" class="form-select">
                        <option value="Monday">Monday</option>
                        <option value="Tuesday">Tuesday</option>
                        <option value="Wednesday">Wednesday</option>
                        <option value="Thursday">Thursday</option>
                        <option value="Friday">Friday</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Start Time Window</label>
                    <select id="moveStartTime" class="form-select">
                        <option value="06:30">06:30 AM</option>
                        <option value="07:30">07:30 AM</option>
                        <option value="08:30">08:30 AM</option>
                        <option value="09:30">09:30 AM</option>
                        <option value="10:30">10:30 AM</option>
                        <option value="11:30">11:30 AM</option>
                        <option value="13:00">01:00 PM</option>
                        <option value="14:00">02:00 PM</option>
                        <option value="15:00">03:00 PM</option>
                        <option value="16:00">04:00 PM</option>
                        <option value="17:00">05:00 PM</option>
                        <option value="18:00">06:00 PM</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Assign Classroom</label>
                    <select id="moveRoomId" class="form-select">
                        @foreach (var r in classrooms)
                        {
                            <option value="@r.Id">@r.RoomNumber (@r.RoomType, Cap: @r.Capacity)</option>
                        }
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary fw-semibold" onclick="submitMove()">Save Shift</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function timeToMinutes(tStr) {
            if (!tStr) return 0;
            var parts = tStr.split(':');
            return parseInt(parts[0], 10) * 60 + parseInt(parts[1], 10);
        }

        function filterTimetableGrid(fromStr, toStr) {
            var fromMin = timeToMinutes(fromStr);
            var toMin = timeToMinutes(toStr);

            if (fromMin >= toMin) {
                alert("The 'From' time must be earlier than the 'To' time.");
                return;
            }

            $('.slot-header').each(function() {
                var startMin = timeToMinutes($(this).attr('data-start'));
                var endMin = timeToMinutes($(this).attr('data-end'));

                if (startMin >= fromMin && endMin <= toMin) {
                    $(this).show();
                } else {
                    $(this).hide();
                }
            });

            $('.slot-cell').each(function() {
                var startMin = timeToMinutes($(this).attr('data-start'));
                var endMin = timeToMinutes($(this).attr('data-end'));

                if (startMin >= fromMin && endMin <= toMin) {
                    $(this).show();
                } else {
                    $(this).hide();
                }
            });

            $('#timeRangeSummary').html('<i class="fa-solid fa-clock me-1 text-primary"></i>Showing Time Range: <strong>' + fromStr + ' - ' + toStr + '</strong>');
        }

        function applyQuickTimeFilter(fromStr, toStr, btn) {
            $('.btn-group button').removeClass('active');
            $(btn).addClass('active');
            $('#gridTimeFrom').val(fromStr);
            $('#gridTimeTo').val(toStr);
            filterTimetableGrid(fromStr, toStr);
        }

        function customTimeFilterChanged() {
            var fromStr = $('#gridTimeFrom').val();
            var toStr = $('#gridTimeTo').val();
            $('.btn-group button').removeClass('active');
            filterTimetableGrid(fromStr, toStr);
        }

        function toggleLock(entryId, btnElement) {
            $.post('/Admin/Timetable/ToggleLock', { entryId: entryId }, function(res) {
                if (res.success) {
                    var icon = $(btnElement).find('i');
                    if (res.isLocked) {
                        icon.removeClass('fa-lock-open').addClass('fa-lock text-danger');
                        toastr.success('Session locked to prevent AI modification.');
                    } else {
                        icon.removeClass('fa-lock text-danger').addClass('fa-lock-open');
                        toastr.info('Session unlocked for AI scheduling.');
                    }
                }
            });
        }

        function openMoveModal(entryId, day, startTime, roomId) {
            $('#moveEntryId').val(entryId);
            $('#moveDay').val(day);
            $('#moveStartTime').val(startTime);
            $('#moveRoomId').val(roomId);
            new bootstrap.Modal(document.getElementById('moveModal')).show();
        }

        function filterGridByDay(day, btn) {
            $('#dayTabNav .nav-link').removeClass('active text-primary').addClass('text-dark');
            $(btn).addClass('active text-primary').removeClass('text-dark');

            if (day === 'ALL') {
                $('.day-grid-row').show();
            } else {
                $('.day-grid-row').hide();
                $('.day-grid-row[data-day="' + day + '"]').show();
            }
        }

        function submitMove() {
            var data = {
                entryId: $('#moveEntryId').val(),
                day: $('#moveDay').val(),
                startTimeStr: $('#moveStartTime').val(),
                roomId: $('#moveRoomId').val()
            };

            $.post('/Admin/Timetable/MoveEntry', data, function(res) {
                if (res.success) {
                    toastr.success('Session moved successfully! Real-time clash scan updated.');
                    location.reload();
                } else {
                    toastr.error(res.message || 'Error moving session.');
                }
            });
        }
    </script>
}
