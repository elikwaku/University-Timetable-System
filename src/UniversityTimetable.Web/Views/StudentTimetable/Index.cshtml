@model IEnumerable<UniversityTimetable.Domain.Entities.TimetableEntry>
@{
    Layout = "_StudentLayout";
    ViewData["Title"] = "Personal Timetable";
    var student = ViewBag.Student as UniversityTimetable.Domain.Entities.Student;
    var timetable = ViewBag.Timetable as UniversityTimetable.Domain.Entities.Timetable;

    var days = new[] { DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday, DayOfWeek.Thursday, DayOfWeek.Friday };
    var timeWindows = new[] {
        new TimeSpan(8,0,0), new TimeSpan(9,0,0), new TimeSpan(10,0,0), new TimeSpan(11,0,0), new TimeSpan(12,0,0),
        new TimeSpan(13,0,0), new TimeSpan(14,0,0), new TimeSpan(15,0,0), new TimeSpan(16,0,0)
    };
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h3 class="fw-bold mb-1"><i class="fa-solid fa-calendar-week text-primary me-2"></i>My Weekly Schedule</h3>
        <p class="text-muted mb-0">Personalized timetable for @(student?.Programme?.Name ?? "Programme") Level @((int)(student?.Level ?? 0)) (@(student?.StudentGroup?.Name ?? "Main Group"))</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/Student/StudentTimetable/ExportPrintHtml" target="_blank" class="btn btn-outline-primary fw-semibold">
            <i class="fa-solid fa-print me-1"></i> Print / Download PDF
        </a>
    </div>
</div>

<!-- Personal Timetable Grid -->
<div class="student-card">
    <div class="p-3 bg-light border-bottom d-flex align-items-center justify-content-between">
        <span class="fw-bold text-dark"><i class="fa-solid fa-calendar-days me-2"></i>Master Timetable Grid</span>
        <span class="badge bg-success"><i class="fa-solid fa-lock me-1"></i>Read-Only Student View</span>
    </div>
    <div class="p-0 overflow-auto">
        <table class="table table-bordered mb-0 text-center align-middle" style="min-width: 900px;">
            <thead class="table-light">
                <tr>
                    <th style="width: 100px;">Time</th>
                    @foreach (var day in days)
                    {
                        <th>@day.ToString()</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var time in timeWindows)
                {
                    bool isBreakTime = (time >= new TimeSpan(12, 0, 0) && time < new TimeSpan(13, 0, 0));
                    <tr style="@(isBreakTime ? "background-color: #fffbeb;" : "")">
                        <td class="fw-bold bg-light text-muted small">@time.ToString(@"hh\:mm")</td>

                        @foreach (var day in days)
                        {
                            var matchingEntries = Model?
                                .Where(e => e.DayOfWeek == day && e.StartTime <= time && e.EndTime > time)
                                .ToList() ?? new List<UniversityTimetable.Domain.Entities.TimetableEntry>();

                            <td>
                                @if (isBreakTime && time == new TimeSpan(12, 0, 0))
                                {
                                    <div class="badge bg-warning text-dark py-2 px-3 w-100 fw-bold">
                                        <i class="fa-solid fa-utensils me-1"></i> OFFICIAL DAILY BREAK (12:30 - 13:00)
                                    </div>
                                }
                                else if (matchingEntries.Any())
                                {
                                    @foreach (var entry in matchingEntries)
                                    {
                                        string bgClass = entry.SessionType == UniversityTimetable.Domain.Enums.SessionType.CombinedClass ? "bg-purple-subtle border-purple text-purple"
                                            : entry.SessionType == UniversityTimetable.Domain.Enums.SessionType.ComputerLab || entry.SessionType == UniversityTimetable.Domain.Enums.SessionType.Lab ? "bg-success-subtle border-success text-success"
                                            : "bg-primary-subtle border-primary text-primary";

                                        <div class="card p-2 text-start shadow-sm mb-1 border @bgClass" style="border-left: 4px solid !important;">
                                            <strong class="fs-6 text-dark">@entry.Course?.Code</strong>
                                            <div class="small fw-semibold text-dark">@entry.Course?.Title</div>
                                            <div class="small text-muted mt-1"><i class="fa-solid fa-door-open me-1 text-primary"></i>Room: @entry.Classroom?.RoomNumber</div>
                                            <div class="small text-muted"><i class="fa-solid fa-user-tie me-1 text-secondary"></i>@entry.Lecturer?.FullName</div>
                                            <div class="mt-1">
                                                <span class="badge @(entry.SessionType == UniversityTimetable.Domain.Enums.SessionType.CombinedClass ? "bg-purple text-white" : "bg-primary")" style="@(entry.SessionType == UniversityTimetable.Domain.Enums.SessionType.CombinedClass ? "background:#9333ea;" : "")">
                                                    @entry.SessionType
                                                </span>
                                            </div>
                                        </div>
                                    }
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
