@model IEnumerable<UniversityTimetable.Domain.Entities.Department>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Department Management";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h3 class="fw-bold mb-1"><i class="fa-solid fa-building-columns text-primary me-2"></i>Department Management</h3>
        <p class="text-muted mb-0">Manage university academic departments, faculties, and associated programmes.</p>
    </div>
    <button class="btn btn-primary fw-semibold" data-bs-toggle="modal" data-bs-target="#createModal">
        <i class="fa-solid fa-plus me-2"></i>Add New Department
    </button>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card-custom">
    <div class="card-body">
        <table class="table table-hover datatable">
            <thead class="table-light">
                <tr>
                    <th>Code</th>
                    <th>Department Name</th>
                    <th>Faculty / School</th>
                    <th>Programmes</th>
                    <th>Lecturers</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dept in Model)
                {
                    <tr>
                        <td><span class="badge bg-primary-subtle text-primary fw-bold fs-6">@dept.Code</span></td>
                        <td class="fw-bold">@dept.Name</td>
                        <td>@dept.Faculty</td>
                        <td><span class="badge bg-info text-white">@dept.Programmes.Count Programmes</span></td>
                        <td><span class="badge bg-secondary">@dept.Lecturers.Count Lecturers</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-1" onclick="editDept(@dept.Id, '@dept.Code', '@dept.Name', '@dept.Faculty')">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </button>
                            <form action="/Admin/Department/Delete" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this department?');">
                                <input type="hidden" name="id" value="@dept.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <form action="/Admin/Department/Create" method="post">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold"><i class="fa-solid fa-plus me-2"></i>Create Department</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Department Code</label>
                        <input type="text" name="Code" class="form-control" placeholder="e.g. CS" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Department Name</label>
                        <input type="text" name="Name" class="form-control" placeholder="e.g. Computer Science & Engineering" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Faculty / School</label>
                        <input type="text" name="Faculty" class="form-control" placeholder="e.g. School of Engineering" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary fw-semibold">Create Department</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <form action="/Admin/Department/Edit" method="post">
            <input type="hidden" name="Id" id="editId" />
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold"><i class="fa-solid fa-pen-to-square me-2"></i>Edit Department</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Department Code</label>
                        <input type="text" name="Code" id="editCode" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Department Name</label>
                        <input type="text" name="Name" id="editName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Faculty / School</label>
                        <input type="text" name="Faculty" id="editFaculty" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary fw-semibold">Save Changes</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function editDept(id, code, name, faculty) {
            $('#editId').val(id);
            $('#editCode').val(code);
            $('#editName').val(name);
            $('#editFaculty').val(faculty);
            new bootstrap.Modal(document.getElementById('editModal')).show();
        }
    </script>
}
