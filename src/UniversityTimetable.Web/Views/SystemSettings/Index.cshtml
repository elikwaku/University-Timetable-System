@model IEnumerable<UniversityTimetable.Domain.Entities.SystemSetting>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Scheduling Rules & Settings";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h3 class="fw-bold mb-1"><i class="fa-solid fa-gears text-primary me-2"></i>Institutional Scheduling Rules</h3>
        <p class="text-muted mb-0">Configure break times, contact hour rules, and constraint policies enforced during AI timetable generation.</p>
    </div>
    <div>
        <button type="button" class="btn btn-primary fw-semibold shadow-sm" data-bs-toggle="modal" data-bs-target="#createRuleModal">
            <i class="fa-solid fa-plus me-1"></i> Add New Rule
        </button>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert">
        <i class="fa-solid fa-triangle-exclamation me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="card-custom p-5 text-center">
        <i class="fa-solid fa-sliders text-muted fs-1 mb-3"></i>
        <h5 class="fw-bold">No Scheduling Rules Found</h5>
        <p class="text-muted">Click the "Add New Rule" button above to create your first scheduling rule.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var setting in Model)
        {
            var categoryBadgeClass = setting.Category switch
            {
                "Scheduling" => "bg-primary",
                "Academic" => "bg-info text-dark",
                "Constraint" => "bg-danger",
                "Resource" => "bg-warning text-dark",
                _ => "bg-secondary"
            };

            <div class="col-md-6">
                <div class="card-custom h-100 p-4 d-flex flex-column justify-content-between position-relative">
                    <div>
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="badge @categoryBadgeClass fs-6 px-2 py-1"><i class="fa-solid fa-tag me-1"></i>@setting.Category</span>
                            <div class="d-flex align-items-center gap-2">
                                <small class="text-muted">Key: <code class="fw-bold fs-6">@setting.Key</code></small>
                                <form action="/Admin/SystemSettings/Delete" method="post" onsubmit="return confirm('Are you sure you want to delete the scheduling rule \'@setting.Key\'?');" class="d-inline">
                                    <input type="hidden" name="id" value="@setting.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm px-2 py-1" title="Delete Rule">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </form>
                            </div>
                        </div>

                        <form action="/Admin/SystemSettings/SaveSetting" method="post">
                            <input type="hidden" name="key" value="@setting.Key" />
                            
                            <div class="mb-3">
                                <label class="form-label text-muted small fw-semibold mb-1">Description</label>
                                <input type="text" name="description" class="form-control form-control-sm text-dark fw-medium" value="@setting.Description" placeholder="Description of this rule..." />
                            </div>

                            <div class="row g-2 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label text-muted small fw-semibold mb-1">Category</label>
                                    <input type="text" name="category" class="form-control form-control-sm" value="@setting.Category" list="categoryOptions" placeholder="Category" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted small fw-semibold mb-1">Rule Value</label>
                                    <input type="text" name="value" class="form-control form-control-sm fw-bold fs-6" value="@setting.Value" required />
                                </div>
                            </div>

                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary btn-sm fw-semibold">
                                    <i class="fa-solid fa-floppy-disk me-1"></i> Save Changes
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- Create Rule Modal -->
<div class="modal fade" id="createRuleModal" tabindex="-1" aria-labelledby="createRuleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form action="/Admin/SystemSettings/Create" method="post">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold" id="createRuleModalLabel">
                        <i class="fa-solid fa-plus-circle text-primary me-2"></i>Add New Scheduling Rule
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="ruleKey" class="form-label fw-semibold">Rule Key <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="ruleKey" name="key" placeholder="e.g., MaxLecturerDailyGaps" required />
                        <div class="form-text">Unique system key used by the scheduling engine (e.g. CamelCase).</div>
                    </div>

                    <div class="mb-3">
                        <label for="ruleCategory" class="form-label fw-semibold">Category</label>
                        <input type="text" class="form-control" id="ruleCategory" name="category" list="categoryOptions" placeholder="Select or enter category..." value="Scheduling" />
                        <datalist id="categoryOptions">
                            <option value="Scheduling"></option>
                            <option value="Academic"></option>
                            <option value="Constraint"></option>
                            <option value="Resource"></option>
                            <option value="General"></option>
                        </datalist>
                    </div>

                    <div class="mb-3">
                        <label for="ruleValue" class="form-label fw-semibold">Rule Value <span class="text-danger">*</span></label>
                        <input type="text" class="form-control fw-bold" id="ruleValue" name="value" placeholder="e.g., 2, 12:30, or true" required />
                    </div>

                    <div class="mb-3">
                        <label for="ruleDescription" class="form-label fw-semibold">Description</label>
                        <textarea class="form-control" id="ruleDescription" name="description" rows="3" placeholder="Describe the purpose or constraint enforced by this rule..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary fw-semibold"><i class="fa-solid fa-plus me-1"></i> Create Rule</button>
                </div>
            </form>
        </div>
    </div>
</div>
