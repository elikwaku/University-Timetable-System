@model IEnumerable<UniversityTimetable.Domain.Entities.SystemSetting>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Scheduling Rules & Settings";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h3 class="fw-bold mb-1"><i class="fa-solid fa-gears text-secondary me-2"></i>Institutional Scheduling Rules</h3>
        <p class="text-muted mb-0">Configure official daily break times, contact hour minimums, and constraint policies.</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    @foreach (var setting in Model)
    {
        <div class="col-md-6">
            <div class="card-custom h-100 p-4">
                <form action="/Admin/SystemSettings/SaveSetting" method="post">
                    <input type="hidden" name="key" value="@setting.Key" />
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="badge bg-secondary">@setting.Category</span>
                        <small class="text-muted">Key: <code>@setting.Key</code></small>
                    </div>
                    <h5 class="fw-bold text-dark mb-1">@setting.Description</h5>
                    <p class="text-muted small mb-3">Defines constraint thresholds enforced during AI timetable generation.</p>
                    <div class="input-group">
                        <input type="text" name="value" class="form-control fw-bold fs-5" value="@setting.Value" required />
                        <button type="submit" class="btn btn-primary fw-semibold"><i class="fa-solid fa-floppy-disk me-1"></i>Save</button>
                    </div>
                </form>
            </div>
        </div>
    }
</div>
