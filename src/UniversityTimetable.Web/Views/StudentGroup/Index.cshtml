@model IEnumerable<UniversityTimetable.Domain.Entities.StudentGroup>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Student Groups & CSV Import";
    var programmes = ViewBag.Programmes as List<UniversityTimetable.Domain.Entities.Programme> ?? new List<UniversityTimetable.Domain.Entities.Programme>();
    var importSuggestions = ViewBag.ImportSuggestions as List<UniversityTimetable.Infrastructure.Services.StudentGroupSuggestion>;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h3 class="fw-bold mb-1"><i class="fa-solid fa-users-rectangle text-purple me-2" style="color:#9333ea;"></i>Student Grouping & Roster Management</h3>
        <p class="text-muted mb-0">Manage student groups, level divisions, and run bulk CSV roster imports with AI auto-grouping suggestions.</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-success fw-semibold" data-bs-toggle="modal" data-bs-target="#importModal">
            <i class="fa-solid fa-file-csv me-2"></i>Import Student CSV
        </button>
        <button class="btn btn-primary fw-semibold" data-bs-toggle="modal" data-bs-target="#createModal">
            <i class="fa-solid fa-plus me-2"></i>Add Student Group
        </button>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (importSuggestions != null && importSuggestions.Any())
{
    <div class="card border-primary mb-4">
        <div class="card-header bg-primary text-white fw-bold d-flex align-items-center justify-content-between">
            <span><i class="fa-solid fa-wand-magic-sparkles me-2"></i>AI Group Division Recommendations</span>
            <span class="badge bg-light text-primary">Capacity Optimization</span>
        </div>
        <div class="card-body">
            <div class="row g-3">
                @foreach (var sug in importSuggestions)
                {
                    <div class="col-md-6">
                        <div class="p-3 border rounded bg-light">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="fw-bold text-dark">@sug.ProgrammeCode - Level @((int)sug.Level)</span>
                                <span class="badge bg-info">Enrolled: @sug.TotalEnrolled</span>
                            </div>
                            <p class="small text-muted mb-2">@sug.Rationale</p>
                            <div class="d-flex gap-2">
                                <span class="badge bg-success">Recommended Groups: @sug.RecommendedGroupsCount</span>
                                <span class="badge bg-secondary">~@sug.RecommendedStudentsPerGroup Students / Group</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="card-custom">
    <div class="card-body">
        <table class="table table-hover datatable">
            <thead class="table-light">
                <tr>
                    <th>Group Name</th>
                    <th>Programme</th>
                    <th>Level</th>
                    <th>Student Capacity</th>
                    <th>Enrolled Students</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var g in Model)
                {
                    <tr>
                        <td><span class="badge bg-purple-subtle text-purple fw-bold fs-6" style="background:#f3e8ff; color:#9333ea;">@g.Name</span></td>
                        <td class="fw-bold">@g.Programme?.Name (@g.Programme?.Code)</td>
                        <td><span class="badge bg-secondary">Level @((int)g.Level)</span></td>
                        <td><span class="badge bg-dark">@g.StudentCount Students</span></td>
                        <td><span class="badge bg-info">@g.Students.Count Enrolled</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-1" onclick="editGroup(@g.Id, '@g.Name', @g.ProgrammeId, @((int)g.Level), @g.StudentCount)">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </button>
                            <form action="/Admin/StudentGroup/Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this student group?');">
                                <input type="hidden" name="id" value="@g.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <form action="/Admin/StudentGroup/Create" method="post">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold"><i class="fa-solid fa-plus me-2"></i>Add Student Group</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Group Name</label>
                        <input type="text" name="Name" class="form-control" placeholder="e.g. Group A or Level 200 Main" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Programme</label>
                        <select name="ProgrammeId" class="form-select" required>
                            @foreach (var p in programmes) { <option value="@p.Id">@p.Name (@p.Code)</option> }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Level</label>
                        <select name="Level" class="form-select">
                            <option value="100">Level 100</option>
                            <option value="200" selected>Level 200</option>
                            <option value="300">Level 300</option>
                            <option value="400">Level 400</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Target Student Count</label>
                        <input type="number" name="StudentCount" class="form-control" value="60" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary fw-semibold">Save Group</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <form action="/Admin/StudentGroup/Edit" method="post">
            <input type="hidden" name="Id" id="editId" />
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold"><i class="fa-solid fa-pen-to-square me-2"></i>Edit Student Group</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Group Name</label>
                        <input type="text" name="Name" id="editName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Programme</label>
                        <select name="ProgrammeId" id="editProgId" class="form-select" required>
                            @foreach (var p in programmes) { <option value="@p.Id">@p.Name (@p.Code)</option> }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Level</label>
                        <select name="Level" id="editLevel" class="form-select">
                            <option value="100">Level 100</option>
                            <option value="200">Level 200</option>
                            <option value="300">Level 300</option>
                            <option value="400">Level 400</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Target Student Count</label>
                        <input type="number" name="StudentCount" id="editCount" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary fw-semibold">Save Changes</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Import Modal -->
<div class="modal fade" id="importModal" tabindex="-1">
    <div class="modal-dialog">
        <form action="/Admin/StudentGroup/ImportCsv" method="post" enctype="multipart/form-data">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold"><i class="fa-solid fa-file-csv me-2"></i>Import Student Roster CSV</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small">Select a CSV file containing student index numbers, full names, emails, programme codes, and level. The AI engine will automatically analyze roster sizes and recommend group divisions.</p>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">CSV File</label>
                        <input type="file" name="csvFile" class="form-control" accept=".csv" required />
                    </div>
                    <div class="alert alert-info small mb-0">
                        <i class="fa-solid fa-circle-info me-1"></i>Expected Columns: <code>IndexNumber, FullName, Email, ProgrammeCode, Level</code>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success fw-semibold">Upload & Analyze</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function editGroup(id, name, progId, level, count) {
            $('#editId').val(id);
            $('#editName').val(name);
            $('#editProgId').val(progId);
            $('#editLevel').val(level);
            $('#editCount').val(count);
            new bootstrap.Modal(document.getElementById('editModal')).show();
        }
    </script>
}
